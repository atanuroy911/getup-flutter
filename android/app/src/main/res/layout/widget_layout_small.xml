<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1B1F"
    android:padding="16dp">

    <!-- Top: Status Label -->
    <TextView
        android:id="@+id/widget_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:text="WORK"
        android:textColor="#4CAF50"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <!-- Center: Timer -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <Chronometer
            android:id="@+id/widget_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:countDown="true"
            android:format="%s"
            android:textColor="#E6E1E5"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_time_static"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#E6E1E5"
            android:textSize="36sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Bottom: Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <ImageButton
            android:id="@+id/widget_btn_reset"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_reset"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Reset Timer"
            android:tint="#CAC4D0"
            android:layout_marginEnd="16dp" />

        <ImageButton
            android:id="@+id/widget_btn_play_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/widget_btn_bg"
            android:src="@drawable/ic_play"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="Play or Pause Timer"
            android:tint="#1C1B1F" />
    </LinearLayout>

    <!-- Bottom Progress Bar -->
    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="-10dp"
        android:layout_marginStart="-10dp"
        android:layout_marginEnd="-10dp"
        android:progressTint="#4CAF50"
        android:progressBackgroundTint="#333333"
        android:max="1000"
        android:progress="500" />

</RelativeLayout>
